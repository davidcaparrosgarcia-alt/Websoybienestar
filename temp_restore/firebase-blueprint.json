{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "hasDoneConsultation": { "type": "boolean" },
        "accumulatedSummary": { "type": "string" },
        "latestSessionTranscript": { "type": "string" },
        "diarySilenced": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "DiaryEntry": {
      "title": "Daily Gratitude Entry",
      "description": "Daily reflections and scores generated by the user and AI",
      "type": "object",
      "properties": {
        "entry1": { "type": "string" },
        "entry2": { "type": "string" },
        "score1": { "type": "integer" },
        "score2": { "type": "integer" },
        "reflection": { "type": "string" },
        "deepReflection": { "type": "string" },
        "hasDeepened": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["entry1", "entry2", "score1", "score2", "reflection"]
    },
    "WeeklyGoal": {
      "title": "Weekly Goal",
      "description": "Weekly goals set by user or AI",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "type", "completed", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and master stats"
    },
    "/users/{userId}/diaryEntries/{dateId}": {
      "schema": "DiaryEntry",
      "description": "Collection of daily diary entries keyed by YYYY-MM-DD"
    },
    "/users/{userId}/weeklyGoals/{goalId}": {
      "schema": "WeeklyGoal",
      "description": "Collection of weekly goals"
    }
  }
}
